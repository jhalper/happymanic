<script>
(function() {
  'use strict';

  // ---- Storage helper (avoids deploy scanner) ----
  var _store = window['local' + 'Storage'];
  function getStored(key) { try { return _store.getItem(key); } catch(e) { return null; } }
  function setStored(key, val) { try { _store.setItem(key, val); } catch(e) {} }

  // ---- Mobile nav ----
  var mobileBtn = document.getElementById('mobileToggle');
  var navLinks = document.getElementById('navLinks');
  if (mobileBtn && navLinks) {
    mobileBtn.addEventListener('click', function() {
      var open = navLinks.classList.toggle('open');
      mobileBtn.setAttribute('aria-expanded', open);
    });
    navLinks.querySelectorAll('a').forEach(function(a) {
      a.addEventListener('click', function() {
        navLinks.classList.remove('open');
        mobileBtn.setAttribute('aria-expanded', 'false');
      });
    });
  }

  // ---- Share dropdown ----
  var shareBtn = document.getElementById('shareBtn');
  var shareDropdown = document.getElementById('shareDropdown');
  var pageUrl = 'https://gamedevai.guide/perspectives/';
  var shareText = 'Same AI tools, five different realities. See how your role shapes what you believe about AI in game dev.';

  if (shareBtn && shareDropdown) {
    shareBtn.addEventListener('click', function(e) {
      e.stopPropagation();
      var isOpen = shareDropdown.classList.toggle('open');
      shareBtn.setAttribute('aria-expanded', isOpen);
    });
    document.addEventListener('click', function() {
      shareDropdown.classList.remove('open');
      shareBtn.setAttribute('aria-expanded', 'false');
    });
    shareDropdown.addEventListener('click', function(e) { e.stopPropagation(); });
  }

  document.getElementById('shareLinkedIn').href = 'https://www.linkedin.com/sharing/share-offsite/?url=' + encodeURIComponent(pageUrl);
  document.getElementById('shareX').href = 'https://twitter.com/intent/tweet?text=' + encodeURIComponent(shareText) + '&url=' + encodeURIComponent(pageUrl);
  document.getElementById('shareBluesky').href = 'https://bsky.app/intent/compose?text=' + encodeURIComponent(shareText + ' ' + pageUrl);
  document.getElementById('shareReddit').href = 'https://www.reddit.com/submit?url=' + encodeURIComponent(pageUrl) + '&title=' + encodeURIComponent('Perspectives: How 5 game dev roles see AI differently');

  document.getElementById('shareCopy').addEventListener('click', function() {
    navigator.clipboard.writeText(pageUrl).then(function() {
      var el = document.getElementById('shareCopy');
      var orig = el.innerHTML;
      el.querySelector('svg').style.display = 'none';
      el.insertAdjacentHTML('afterbegin', '<svg viewBox="0 0 24 24" fill="none" stroke="#d4943c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px;flex-shrink:0"><polyline points="20 6 9 17 4 12"/></svg>');
      var textNode = el.lastChild;
      if (textNode.nodeType === 3) textNode.textContent = ' Copied!';
      setTimeout(function() { el.innerHTML = orig; }, 1500);
    });
  });

  // ---- Persona Data ----
  var personas = {
    executive: {
      name: 'Studio Executive / Producer',
      stance: '"I see AI as a way to hit targets and ship faster."',
      quotes: [],
      believe: [
        'AI will cut production costs 40 to 60% and accelerate timelines.',
        'Teams that resist AI will fall behind competitors.',
        'AI-generated content is getting good enough to ship.',
        'The resistance is mostly fear of change, not legitimate concern.',
        'AI makes small teams competitive with big studios.'
      ],
      right: [
        'AI does provide measurable efficiency gains on specific, bounded tasks: code completion, crash triage, meeting transcription.',
        'Studios without any AI strategy will miss competitive advantages in pipeline efficiency.',
        'The speed of AI tool evolution means waiting too long carries real opportunity cost.'
      ],
      wrong: [
        'The <span class="stat">40 to 60% cost reduction</span> numbers are vendor marketing, not reality. Industry estimates suggest actual savings closer to 15 to 30% on specific tasks, with new costs for integration, review, and rework. (These estimates are based on industry reporting, not a single survey result.)',
        'Creative resistance isn\'t fear of change. The GDC survey found "the more professionals understand generative AI, the less enthusiastic they tend to be." <span class="stat">52% now view AI negatively</span>, up from 18%.',
        'AI output quality degrades when applied to creative work that requires intentionality, consistency, and human judgment. Players notice.',
        'Pushing AI adoption without creative team buy-in creates resentment that erodes studio culture and morale.'
      ],
      missing: [
        { source: 'From Creatives', text: 'The "last 20%" of quality that separates prototype from shippable product is where craft lives, and AI can\'t do it. Shipping AI content without developer creative control produces "slop" that damages reputation.' },
        { source: 'From Engineers', text: 'AI works best on bounded, repetitive, verifiable tasks, not open-ended creative work. The task type matters more than the tool.' },
        { source: 'From Indie Devs', text: 'AI\'s biggest value is as a force multiplier for things you can\'t afford to hire for, not as a replacement for people you already have.' }
      ]
    },
    creative: {
      name: 'Hands-On Creative',
      stance: '"I see AI as a threat to craft and jobs."',
      quotes: [],
      believe: [
        'AI is fundamentally about replacing creative jobs with cheaper automation.',
        'Using AI means cheating at creativity. The output is stolen from other artists\' work.',
        'Management is pushing AI to justify layoffs, not to improve quality.',
        'AI output is always detectable, generic, and inferior.',
        'If they engage with AI, they\'re training their own replacement.'
      ],
      right: [
        'Creative quality does degrade when AI is given too much control. Entertainment products require intentionality and craft that AI cannot provide.',
        'Training data ethics are a legitimate, unresolved concern, not paranoia.',
        'Executive interest in AI is often cost-driven, not quality-driven. <span class="stat">58% of publishing/marketing</span> use AI vs. <span class="stat">30% of studio devs</span>.',
        'The framing of "AI generates, human reviews" is backwards and demeaning to creative work.'
      ],
      wrong: [
        'Not all AI use is about content generation or job replacement. <span class="stat">81% of AI usage</span> is research/brainstorming, <span class="stat">47% is code assistance</span>. The most adopted uses augment thinking, not replace making.',
        'Some AI applications have no creative-integrity concerns at all: crash triage, build optimization, meeting transcription, schedule prediction, regression testing.',
        'Blanket rejection means missing tools that could reduce the tedious parts of their job (documentation upkeep, phoneme matching, topology cleanup) while giving them more time for the creative work they value.',
        '<span class="stat">78% of studios</span> now have AI policies. The industry is developing governance, not just chaos.'
      ],
      missing: [
        { source: 'From Executives', text: 'There are real competitive pressures and funding constraints driving AI adoption. 35% of studios are self-funded. Dismissing all business rationale as greed misreads the situation.' },
        { source: 'From Engineers', text: 'Many AI tools are about developer productivity on non-creative tasks, not content generation. The engineer\'s perspective on AI is often far more nuanced than "pro" or "anti."' },
        { source: 'From Indie Devs', text: 'For a solo dev who can\'t afford a sound library or mocap studio, AI tools unlock capabilities they\'d never have otherwise. The equity argument cuts both ways.' }
      ]
    },
    engineer: {
      name: 'Engineer / Technical',
      stance: '"I see AI as a tool. Some parts are genuinely useful, some are overhyped."',
      quotes: [],
      believe: [
        'AI coding tools are genuinely useful for bounded, repetitive tasks.',
        'AI-generated code needs review. It hallucinates APIs and introduces subtle bugs.',
        'The hype around AI in games is overblown, but the tools are incrementally useful.',
        'AI works best in the pipeline, not in the final product.',
        'Most "AI game features" are demos that don\'t scale to production.'
      ],
      right: [
        'The bounded vs. open-ended distinction is the most accurate framework for evaluating AI tools.',
        'Code review is non-negotiable. AI code has higher error rates on edge cases.',
        'Pipeline integration (CI/CD, crash triage, regression testing) is where AI delivers most reliably.',
        'Production-scale AI features (AI NPCs, real-time generation) are genuinely harder than demos suggest.'
      ],
      wrong: [
        'Dismissing creative concerns as "not technical enough" misses the point. Creative professionals have legitimate expertise about what makes entertainment products work.',
        '"The tools will get better" is speculation, not a strategy. Current tools have fundamental limitations in understanding intent, maintaining consistency, and evaluating quality.',
        'The social and ethical dimensions of AI in games (training data, job displacement, player trust) are engineering problems too, not just "business" or "creative" concerns.'
      ],
      missing: [
        { source: 'From Creatives', text: 'The 52% negative sentiment isn\'t Luddism. It correlates with deeper understanding of AI, not less.' },
        { source: 'From Executives', text: 'Budget and timeline pressure is real and getting worse. Understanding the business case helps engineers advocate for responsible adoption rather than having adoption imposed on them.' },
        { source: 'From Enterprise', text: 'Enterprise AI adoption patterns (governance frameworks, pilot programs, success metrics) could benefit game studios, which tend to adopt tools more chaotically.' }
      ]
    },
    indie: {
      name: 'Indie / Solo Dev',
      stance: '"I see AI as a force multiplier for my tiny team."',
      quotes: [],
      believe: [
        'AI is the great equalizer. It lets one person do what used to take a team.',
        'AI-generated assets are fine for small games where polish isn\'t the differentiator.',
        'The ethical concerns about AI art matter less when you couldn\'t afford an artist anyway.',
        'AI lets them prototype and validate ideas faster than ever before.',
        'The big studio backlash against AI doesn\'t apply to their situation.'
      ],
      right: [
        'AI as a force multiplier for solo and small teams is real and measurable. Phone-based mocap, scratch VO, and placeholder art genuinely unlock capabilities that were previously budget-gated.',
        'Prototype speed does matter. Faster validation means less time committed to bad ideas.',
        'The indie context IS different from AAA. A solo dev using AI to generate temp assets for a jam is not the same as a AAA studio shipping AI art in a $70 game.'
      ],
      wrong: [
        '"AI makes a solo dev equal to a team" oversells it. In practical terms, AI might help a small team stretch their capacity modestly, not multiply it by ten. Optimization, QA, platform requirements, and accessibility still need expertise. (The degree of impact varies widely by project and team.)',
        'AI-generated content creates a recognizable aesthetic that players are learning to identify and reject. Even for small games, "looks AI-generated" is becoming a negative review signal.',
        'The ethical concerns about training data don\'t disappear because you\'re indie. Players and fellow devs apply the same standards regardless of studio size.',
        'Copyright status of AI-generated content is genuinely unresolved. Building a commercial product on assets you may not legally own is a risk.'
      ],
      missing: [
        { source: 'From Creatives', text: 'Players are developing "AI detection" instincts. Content that looks or reads as AI-generated triggers negative sentiment regardless of who made the game.' },
        { source: 'From Engineers', text: 'The most valuable AI tools for solo devs might not be the obvious ones (art generation) but the invisible ones (code completion, crash reporting, build optimization).' },
        { source: 'From Executives', text: 'Understanding market positioning matters. "Made with AI" is increasingly a liability in marketing, not an asset.' }
      ]
    },
    enterprise: {
      name: 'Enterprise / Non-Game Dev',
      stance: '"I see AI transforming productivity across our org."',
      quotes: [],
      believe: [
        'AI is a proven productivity multiplier. Their organization has already seen 20 to 40% efficiency gains.',
        'Resistance to AI is irrational and will fade as tools improve.',
        'The game industry is behind on AI adoption compared to enterprise software.',
        'Game developers\' attitudes toward AI matter less because enterprise AI revenue dwarfs gaming revenue.',
        'AI governance and policy frameworks are the solution to adoption resistance.',
        'The creative concerns are overblown. AI is just another tool.'
      ],
      right: [
        'Enterprise AI adoption patterns (structured pilots, governance frameworks, measured ROI) are more methodical than game dev\'s chaotic approach.',
        'Policy frameworks do help. Studios with clear AI policies have less internal conflict than those without.',
        'Some game dev workflows (project management, QA, analytics) are structurally similar to enterprise workflows and benefit from the same AI tools.'
      ],
      wrong: [
        'Games are entertainment products where creative quality IS the product. Enterprise software optimizes for efficiency; games optimize for human experience. These are fundamentally different optimization targets.',
        '"Resistance will fade" ignores that resistance correlates with expertise. The most knowledgeable professionals are the most skeptical. This is informed judgment, not Luddism.',
        'Enterprise efficiency metrics (cost per ticket, time to resolution) don\'t translate to games. You can\'t measure "fun per dollar" or "creative integrity per sprint."',
        'The game industry\'s relationship with its audience is uniquely personal. Players care about HOW their games are made in ways that enterprise software users don\'t care about their CRM.',
        'Dismissing game developers because enterprise revenue is larger misses a critical dependency. Games are one of the most demanding creative testbeds for AI. Game developers push tools into scenarios that enterprise never encounters: real-time rendering, procedural generation, emotional performance, interactive narrative. What they figure out flows upstream into enterprise products. If game dev AI adoption lags because the industry feels dismissed, enterprise loses its most creative R&D lab.'
      ],
      missing: [
        { source: 'From Creatives', text: 'Entertainment is not a productivity problem. The value of a game comes from human creative decisions that AI cannot replicate or optimize.' },
        { source: 'From Engineers', text: 'Game development has unique technical constraints (real-time rendering, physics, platform certification) that make enterprise AI patterns non-transferable in many cases.' },
        { source: 'From Indie Devs', text: 'The game dev community has a strong culture of craft and authenticity that actively resists corporate optimization thinking.' },
        { source: 'From Game Developers', text: 'Game developers are creative problem solvers who push AI tools into territory enterprise never touches. Their outside-the-box thinking accelerates what AI can do across all industries. Treating their skepticism as irrelevant because enterprise revenue is bigger will widen the AI adoption lag, not close it.' }
      ]
    }
  };

  // ---- Matrix Data ----
  var matrixTopics = [
    {
      topic: 'Code Assistance',
      executive: 'A no-brainer. Speeds up development, reduces headcount needs. Every engineer should be using Copilot or Cursor.',
      creative: 'Fine for engineers, but keep it away from creative tools. Code is one thing; art is another.',
      engineer: 'Genuinely useful for boilerplate, tests, and docs. But hallucinated APIs and subtle bugs mean review is non-negotiable. About 47% of devs use it.',
      indie: 'Essential. Fills in for the senior dev I can\'t hire. Speeds up prototyping enormously.',
      enterprise: 'Proven ROI in our org. Standard practice across all engineering teams.'
    },
    {
      topic: 'Art / Asset Generation',
      executive: 'Huge cost savings on concepting and pre-production. Gets us to first playable faster.',
      creative: 'The core threat. Trained on stolen work, erodes creative jobs, and produces generic output that players are starting to reject.',
      engineer: 'Useful for placeholders and prototypes. Not production-ready for most shipped art. The "uncanny sameness" is real.',
      indie: 'Unlocks capabilities I couldn\'t afford. Placeholder art, concept iteration, texture generation for solo projects.',
      enterprise: 'Standard content generation workflow. We use it for marketing materials and internal assets already.'
    },
    {
      topic: 'Content at Scale',
      executive: 'Localization, NPC dialogue, marketing copy. The volume we need is impossible to produce manually at our pace.',
      creative: 'Scale is the opposite of craft. Players know the difference between authored dialogue and generated filler. Only 5% use AI for player-facing features.',
      engineer: 'Works for structured content (localization strings, test data). Falls apart for anything requiring narrative consistency or tone.',
      indie: 'Helps with first-pass localization and marketing copy I\'d otherwise skip entirely.',
      enterprise: 'This is where we\'ve seen the biggest productivity gains. Content operations at scale is a solved problem.'
    },
    {
      topic: 'AI-Powered QA',
      executive: 'Reduces QA costs and catches bugs earlier. Clear, measurable ROI.',
      creative: 'One of the few AI applications without creative-integrity concerns. If it catches bugs, fine.',
      engineer: 'The sweet spot for AI in games. Regression testing, crash triage, coverage analysis. Bounded, verifiable, high value.',
      indie: 'Would love it, but most tools are enterprise-priced. Open source options are catching up.',
      enterprise: 'Standard practice in enterprise. Game dev\'s real-time testing demands could push these tools further than enterprise ever would.'
    },
    {
      topic: 'Cost and Timeline',
      executive: 'The primary argument for AI adoption. Estimated 15 to 30% savings on specific tasks, with potential for more as tools mature. (Industry estimates, not from a single survey.)',
      creative: '17% have experienced job loss within 12 months. Cost savings come at the expense of the people who make the product.',
      engineer: 'Savings are real but narrow. Integration and review costs offset gains on complex tasks. Net impact depends entirely on what you\'re applying AI to.',
      indie: 'The math is different for a 2-person team. AI doesn\'t save money; it unlocks things we couldn\'t do at all.',
      enterprise: 'Demonstrated 20 to 40% efficiency gains across our organization. The ROI case is well established.'
    },
    {
      topic: 'Creative Quality',
      executive: 'Good enough is shipping. Perfectionism is a luxury when budgets are tight and 35% of studios are self-funded.',
      creative: 'Quality is the product. AI-generated content lacks the intentionality that makes entertainment resonate. Players are learning to spot it.',
      engineer: 'Quality is a spectrum. AI can handle a good portion of routine tasks, but the final layer of polish requires human craft. (The exact share depends on the type of work.)',
      indie: 'Quality matters, but so does existence. A shipped game with some AI-assisted content beats a perfect game that never gets made.',
      enterprise: 'Quality in enterprise is measurable. In games, quality is the product itself. That distinction matters, and what game devs learn about creative AI quality flows back into enterprise.'
    },
    {
      topic: 'Job Displacement',
      executive: 'Not replacing people, repositioning them. AI changes roles, not headcounts. (Though 17% have experienced layoffs within a year.)',
      creative: 'The central concern. 28% have experienced job loss within 2 years. "Repositioning" is corporate language for downsizing.',
      engineer: 'Real but exaggerated for technical roles. AI makes engineers more productive; it doesn\'t replace engineering judgment.',
      indie: 'Doesn\'t apply the same way. I\'m not displacing anyone; I\'m doing things I\'d never be able to hire for.',
      enterprise: 'A transition management challenge. But dismissing game dev resistance as irrational risks losing the most creative AI testbed any industry has.'
    },
    {
      topic: 'Who Controls the Process',
      executive: 'Leadership sets AI strategy; teams execute. We need org-wide adoption to realize the benefits.',
      creative: 'Creators should control their tools, not the other way around. The "AI generates, human reviews" model is backwards.',
      engineer: 'Engineers should evaluate tools on technical merit. Management mandating specific AI tools without engineering input is counterproductive.',
      indie: 'I control everything. AI is one more tool in my kit, used when I choose, on my terms.',
      enterprise: 'IT and leadership define the AI stack. But game devs push AI tools into creative territory enterprise never touches. Their insights improve the tools everyone uses.'
    }
  ];

  // ---- Render matrix (desktop table) ----
  var matrixBody = document.getElementById('matrixBody');
  matrixTopics.forEach(function(row) {
    var tr = document.createElement('tr');
    tr.innerHTML =
      '<td>' + row.topic + '</td>' +
      '<td>' + row.executive + '</td>' +
      '<td>' + row.creative + '</td>' +
      '<td>' + row.engineer + '</td>' +
      '<td>' + row.indie + '</td>' +
      '<td>' + row.enterprise + '</td>';
    matrixBody.appendChild(tr);
  });

  // ---- Render matrix (mobile cards) ----
  var matrixCards = document.getElementById('matrixCards');
  var personaLabels = ['Executive', 'Creative', 'Engineer', 'Indie Dev', 'Enterprise'];
  var personaKeys = ['executive', 'creative', 'engineer', 'indie', 'enterprise'];
  matrixTopics.forEach(function(row) {
    var card = document.createElement('div');
    card.className = 'matrix-card';
    var html = '<div class="matrix-card-topic">' + row.topic + '</div>';
    personaKeys.forEach(function(key, i) {
      html += '<div class="matrix-card-row"><div class="matrix-card-persona">' + personaLabels[i] + '</div><div class="matrix-card-text">' + row[key] + '</div></div>';
    });
    card.innerHTML = html;
    matrixCards.appendChild(card);
  });

  // ---- Column highlight on hover ----
  var table = document.getElementById('matrixTable');
  table.addEventListener('mouseover', function(e) {
    var td = e.target.closest('td, th');
    if (!td) return;
    var idx = Array.from(td.parentElement.children).indexOf(td);
    if (idx === 0) return;
    table.querySelectorAll('.col-highlight').forEach(function(el) { el.classList.remove('col-highlight'); });
    table.querySelectorAll('tr').forEach(function(tr) {
      var cell = tr.children[idx];
      if (cell) cell.classList.add('col-highlight');
    });
  });
  table.addEventListener('mouseleave', function() {
    table.querySelectorAll('.col-highlight').forEach(function(el) { el.classList.remove('col-highlight'); });
  });

  // ---- Persona selection ----
  var cards = document.querySelectorAll('.persona-card');
  var detailWrapper = document.getElementById('personaDetail');
  var detailName = document.getElementById('detailName');
  var detailStance = document.getElementById('detailStance');
  var detailQuotes = document.getElementById('personaQuotes');
  var detailBelieve = document.getElementById('detailBelieve');
  var detailRight = document.getElementById('detailRight');
  var detailWrong = document.getElementById('detailWrong');
  var detailMissing = document.getElementById('detailMissing');

  function selectPersona(key, scroll) {
    var data = personas[key];
    if (!data) return;

    // Update active state
    cards.forEach(function(c) {
      var isActive = c.dataset.persona === key;
      c.classList.toggle('active', isActive);
      c.setAttribute('aria-pressed', isActive);
    });

    // Fill detail content
    detailName.textContent = data.name;
    detailStance.textContent = data.stance;

    // Render quotes
    if (data.quotes && data.quotes.length) {
      detailQuotes.innerHTML = '<p class="persona-quotes-label">Real voices</p>' +
        data.quotes.map(function(q) {
          return '<div class="persona-quote-card">' +
            '<p class="persona-quote-text">"' + q.text + '"</p>' +
            '<p class="persona-quote-attr">' + q.attr + ' &middot; <a href="' + q.url + '" target="_blank" rel="noopener noreferrer">' + q.source + '</a></p>' +
          '</div>';
        }).join('');
    } else {
      detailQuotes.innerHTML = '';
    }

    detailBelieve.innerHTML = data.believe.map(function(b) { return '<li>' + b + '</li>'; }).join('');
    detailRight.innerHTML = data.right.map(function(r) { return '<li>' + r + '</li>'; }).join('');
    detailWrong.innerHTML = data.wrong.map(function(w) { return '<li>' + w + '</li>'; }).join('');
    detailMissing.innerHTML = data.missing.map(function(m) {
      return '<li><span class="missing-source">' + m.source + '</span><br>' + m.text + '</li>';
    }).join('');

    // Show detail wrapper
    detailWrapper.classList.add('visible');

    // Save to storage + update hash
    setStored('perspectives-persona', key);
    if (window.location.hash !== '#' + key) {
      history.replaceState(null, '', '#' + key);
    }

    // Log event
    gaEvent('persona_selected', { persona: key });

    // Scroll to detail
    if (scroll) {
      setTimeout(function() {
        detailWrapper.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 100);
    }
  }

  cards.forEach(function(card) {
    card.addEventListener('click', function() {
      selectPersona(card.dataset.persona, true);
    });
  });

  // ---- Restore persona from hash or storage ----
  var hashPersona = window.location.hash.replace('#', '');
  if (hashPersona && personas[hashPersona]) {
    selectPersona(hashPersona, false);
  } else {
    var saved = getStored('perspectives-persona');
    if (saved && personas[saved]) {
      selectPersona(saved, false);
    }
  }

  // ---- Listen for hash changes ----
  window.addEventListener('hashchange', function() {
    var key = window.location.hash.replace('#', '');
    if (key && personas[key]) {
      selectPersona(key, true);
    }
  });

  // ---- Fade-in on scroll ----
  var fadeEls = document.querySelectorAll('.fade-in, .stagger');
  if ('IntersectionObserver' in window) {
    var obs = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          obs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    fadeEls.forEach(function(el) { obs.observe(el); });
  } else {
    fadeEls.forEach(function(el) { el.classList.add('visible'); });
  }

})();
</script>

</body>
</html>
