<!-- Fonts: Cabinet Grotesk (display) + Satoshi (body) -->
<link rel="preconnect" href="https://api.fontshare.com" crossorigin>
<link href="https://api.fontshare.com/v2/css?f[]=cabinet-grotesk@400,500,700,800&f[]=satoshi@400,500,700&display=swap" rel="stylesheet">

<style>
/* ============================================
   RESET
   ============================================ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html {
  -moz-text-size-adjust: none;
  -webkit-text-size-adjust: none;
  text-size-adjust: none;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  text-rendering: optimizeLegibility;
  scroll-behavior: smooth;
  scroll-padding-top: 5rem;
}

body {
  min-height: 100dvh;
  line-height: 1.6;
  font-family: var(--font-body, sans-serif);
  font-size: var(--text-base);
  color: var(--color-text);
  background-color: var(--color-bg);
  display: flex;
  flex-direction: column;
}

img, picture, video, canvas, svg { display: block; max-width: 100%; height: auto; }
ul[role="list"], ol[role="list"] { list-style: none; }
input, button, textarea, select { font: inherit; color: inherit; }
h1, h2, h3, h4, h5, h6 { text-wrap: balance; line-height: 1.15; }
p, li, figcaption { text-wrap: pretty; max-width: 72ch; }

::selection {
  background: rgba(212, 148, 60, 0.25);
  color: var(--color-text);
}

:focus-visible {
  outline: 2px solid var(--color-primary);
  outline-offset: 3px;
  border-radius: var(--radius-sm);
}

@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
    scroll-behavior: auto !important;
  }
}

button { cursor: pointer; background: none; border: none; }
table { border-collapse: collapse; width: 100%; }

a, button, [role="button"], [role="link"], input, textarea, select {
  transition: color var(--transition-interactive),
              background var(--transition-interactive),
              border-color var(--transition-interactive),
              box-shadow var(--transition-interactive);
}

.sr-only {
  position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
  overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border-width: 0;
}

/* ============================================
   DESIGN TOKENS (matching hub exactly)
   ============================================ */
:root {
  --text-xs:   0.8rem;
  --text-sm:   0.925rem;
  --text-base: 1.05rem;
  --text-lg:   1.3rem;
  --text-xl:   1.75rem;
  --text-2xl:  clamp(2rem, 1.2rem + 2.5vw, 3.2rem);
  --text-3xl:  clamp(2.8rem, 1rem + 4.5vw, 5rem);

  --space-1: 0.25rem; --space-2: 0.5rem; --space-3: 0.75rem;
  --space-4: 1rem; --space-5: 1.25rem; --space-6: 1.5rem;
  --space-8: 2rem; --space-10: 2.5rem; --space-12: 3rem;
  --space-16: 4rem; --space-20: 5rem; --space-24: 6rem; --space-32: 8rem;

  --radius-sm: 2px; --radius-md: 4px; --radius-lg: 6px;

  --transition-interactive: 180ms cubic-bezier(0.16, 1, 0.3, 1);
  --content-wide: 1100px;

  --font-display: 'Cabinet Grotesk', 'Trebuchet MS', sans-serif;
  --font-body: 'Satoshi', 'Inter', sans-serif;

  --color-bg:             #121110;
  --color-surface:        #191817;
  --color-surface-2:      #211f1e;
  --color-surface-3:      #292726;
  --color-border:         #333130;
  --color-border-subtle:  #272524;

  --color-text:           #ece8e1;
  --color-text-secondary: #b5b0a8;
  --color-text-muted:     #8a857e;
  --color-text-faint:     #5c5955;

  --color-primary:        #d4943c;
  --color-primary-hover:  #e8a84e;
  --color-nvidia:         #76b900;
}

/* ============================================
   LAYOUT
   ============================================ */
.container {
  width: 100%;
  max-width: var(--content-wide);
  margin: 0 auto;
  padding-inline: var(--space-6);
}

/* ============================================
   NAV (exact hub match)
   ============================================ */
.nav {
  position: sticky; top: 0; z-index: 100;
  background: rgba(18,17,16,0.96);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--color-border-subtle);
  padding: var(--space-3) 0;
}

.nav-inner {
  display: flex; align-items: center; justify-content: space-between;
  gap: var(--space-4); flex-wrap: nowrap;
}

.nav-right { display: flex; align-items: center; gap: var(--space-1); flex-shrink: 0; }

.nav-logo {
  display: flex; align-items: center; gap: var(--space-2);
  text-decoration: none; color: var(--color-text);
}
.nav-logo svg { width: 26px; height: 26px; flex-shrink: 0; }
.nav-logo-text {
  font-family: var(--font-display); font-weight: 700;
  font-size: var(--text-sm); letter-spacing: -0.01em; white-space: nowrap;
}

.nav-links { display: flex; align-items: center; gap: 0; list-style: none; }
.nav-links a {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 7px 14px; font-size: var(--text-xs); font-weight: 500;
  color: var(--color-text-muted); text-decoration: none;
  border-bottom: 2px solid transparent;
  transition: color var(--transition-interactive), border-color var(--transition-interactive);
}
.nav-links a:hover { color: var(--color-text); }
.nav-links a.active { color: var(--color-primary); border-bottom-color: var(--color-primary); }
.nav-dot { display: inline-block; width: 5px; height: 5px; border-radius: 50%; flex-shrink: 0; }

.nav-mobile-toggle { display: none; padding: var(--space-2); color: var(--color-text-muted); }

@media (max-width: 640px) {
  .nav-links {
    display: none; position: absolute; top: 100%; left: 0; right: 0;
    flex-direction: column; background: var(--color-surface);
    border-bottom: 1px solid var(--color-border); padding: var(--space-2); gap: 0;
  }
  .nav-links.open { display: flex; }
  .nav-links a { width: 100%; padding: var(--space-3) var(--space-4); border-bottom: none; }
  .nav-mobile-toggle { display: flex; align-items: center; }
}

/* ============================================
   HERO
   ============================================ */
.hero {
  padding: clamp(var(--space-12), 6vw, var(--space-20)) 0 clamp(var(--space-10), 4vw, var(--space-16));
  border-bottom: 1px solid var(--color-border-subtle);
}

.hero-content {
  max-width: 680px;
}

.hero-label {
  font-family: var(--font-body); font-size: var(--text-xs); font-weight: 600;
  color: var(--color-primary); letter-spacing: 0.1em; text-transform: uppercase;
  margin-bottom: var(--space-5);
}

.hero h1 {
  font-family: var(--font-display); font-size: var(--text-3xl);
  font-weight: 800; letter-spacing: -0.03em; line-height: 1.02;
  color: var(--color-text); margin-bottom: var(--space-6);
}

.hero-sub {
  font-size: var(--text-base); color: var(--color-text-secondary);
  line-height: 1.7; margin-bottom: var(--space-5); max-width: 54ch;
}

.hero-byline { font-size: var(--text-sm); color: var(--color-text-muted); }
.hero-byline a { color: var(--color-primary); text-decoration: none; }
.hero-byline a:hover { text-decoration: underline; }

.hero-disclaimer {
  font-size: var(--text-xs); color: var(--color-text-faint);
  line-height: 1.6; margin-top: var(--space-4);
  padding: var(--space-3) var(--space-4);
  background: var(--color-surface); border-radius: var(--radius-md);
  border-left: 2px solid var(--color-border);
  max-width: 54ch;
}
.hero-disclaimer a { color: var(--color-text-muted); text-decoration: underline; }
.hero-disclaimer a:hover { color: var(--color-primary); }

/* ============================================
   PERSONA SELECTOR
   ============================================ */
.persona-section {
  padding: var(--space-12) 0 var(--space-8);
}

.section-label {
  font-family: var(--font-display); font-size: var(--text-lg);
  font-weight: 700; color: var(--color-text); margin-bottom: var(--space-6);
  letter-spacing: -0.01em;
}

.persona-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: var(--space-3);
}

@media (max-width: 860px) {
  .persona-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}
@media (max-width: 540px) {
  .persona-grid {
    grid-template-columns: 1fr;
    gap: var(--space-2);
  }
}

.persona-card {
  position: relative;
  padding: var(--space-5) var(--space-4);
  background: var(--color-surface);
  border: 1px solid var(--color-border-subtle);
  border-radius: var(--radius-lg);
  cursor: pointer;
  transition: all var(--transition-interactive);
  text-align: left;
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.persona-card::before {
  content: '';
  position: absolute;
  top: 0; left: var(--space-4); right: var(--space-4);
  height: 2px;
  background: var(--color-primary);
  opacity: 0;
  transition: opacity var(--transition-interactive);
}

.persona-card:hover {
  background: var(--color-surface-2);
  border-color: var(--color-border);
}
.persona-card:hover::before {
  opacity: 0.4;
}

.persona-card.active {
  background: var(--color-surface-2);
  border-color: var(--color-primary);
}
.persona-card.active::before {
  opacity: 0.8;
}

.persona-card-title {
  font-family: var(--font-display);
  font-size: var(--text-sm);
  font-weight: 700;
  color: var(--color-text);
  line-height: 1.3;
}

.persona-card.active .persona-card-title {
  color: var(--color-primary);
}

.persona-card-quote {
  font-size: var(--text-xs);
  color: var(--color-text-muted);
  line-height: 1.5;
  font-style: italic;
}

/* ============================================
   PERSONA DETAIL VIEW
   ============================================ */
.persona-detail-wrapper {
  overflow: hidden;
  max-height: 0;
  opacity: 0;
  transition: max-height 500ms cubic-bezier(0.16, 1, 0.3, 1),
              opacity 350ms cubic-bezier(0.16, 1, 0.3, 1);
}

.persona-detail-wrapper.visible {
  max-height: 4000px;
  opacity: 1;
}

.persona-detail {
  padding: var(--space-8) 0 var(--space-12);
}

.persona-detail-header {
  margin-bottom: var(--space-8);
  padding-bottom: var(--space-6);
  border-bottom: 1px solid var(--color-border-subtle);
}

.persona-detail-name {
  font-family: var(--font-display);
  font-size: var(--text-xl);
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: var(--space-2);
  letter-spacing: -0.02em;
}

.persona-detail-stance {
  font-size: var(--text-base);
  color: var(--color-text-secondary);
  font-style: italic;
  line-height: 1.6;
}

.detail-columns {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-8);
}

@media (max-width: 700px) {
  .detail-columns {
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }
}

.detail-block {
  padding: var(--space-6);
  background: var(--color-surface);
  border: 1px solid var(--color-border-subtle);
  border-radius: var(--radius-lg);
}

.detail-block-label {
  font-family: var(--font-display);
  font-size: var(--text-sm);
  font-weight: 700;
  color: var(--color-primary);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-bottom: var(--space-4);
}

.detail-block--right .detail-block-label {
  color: var(--color-text-muted);
}

.detail-block--blindspots .detail-block-label {
  color: #c45c4a;
}

.detail-block--missing .detail-block-label {
  color: #6ba3a0;
}

.detail-block ul {
  list-style: none;
  padding: 0;
  margin: 0;
}

.detail-block li {
  font-size: var(--text-sm);
  color: var(--color-text-secondary);
  line-height: 1.7;
  padding: var(--space-3) 0;
  border-bottom: 1px solid var(--color-border-subtle);
  max-width: none;
}

.detail-block li:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.detail-block li:first-child {
  padding-top: 0;
}

.detail-block li strong {
  color: var(--color-text);
  font-weight: 600;
}

.detail-block .stat {
  color: var(--color-primary);
  font-weight: 600;
}

.detail-block-note {
  font-size: var(--text-xs); color: var(--color-text-faint);
  font-style: italic; line-height: 1.5;
  margin-bottom: var(--space-4); padding-bottom: var(--space-3);
  border-bottom: 1px solid var(--color-border-subtle);
}

/* Persona quotes */
.persona-quotes {
  margin-bottom: var(--space-8);
}

.persona-quotes-label {
  font-family: var(--font-display);
  font-size: var(--text-xs); font-weight: 700;
  color: var(--color-text-muted); text-transform: uppercase;
  letter-spacing: 0.06em; margin-bottom: var(--space-4);
}

.persona-quote-card {
  padding: var(--space-4) var(--space-5);
  background: var(--color-surface);
  border-left: 2px solid var(--color-primary);
  border-radius: 0 var(--radius-md) var(--radius-md) 0;
  margin-bottom: var(--space-3);
}

.persona-quote-text {
  font-size: var(--text-sm); color: var(--color-text-secondary);
  line-height: 1.65; font-style: italic;
  margin-bottom: var(--space-2);
}

.persona-quote-attr {
  font-size: var(--text-xs); color: var(--color-text-faint);
  line-height: 1.4;
}

.persona-quote-attr a {
  color: var(--color-text-muted); text-decoration: underline;
}
.persona-quote-attr a:hover { color: var(--color-primary); }

/* Full-width detail blocks (believe + missing) */
.detail-full-row {
  margin-bottom: var(--space-6);
}

.detail-full-row .detail-block {
  width: 100%;
}

.detail-full-row .detail-block ul {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0 var(--space-6);
}

@media (max-width: 700px) {
  .detail-full-row .detail-block ul {
    grid-template-columns: 1fr;
  }
}

.detail-full-row .detail-block li {
  border-bottom: 1px solid var(--color-border-subtle);
}

/* "What you're missing" source labels */
.missing-source {
  display: inline-block;
  font-size: var(--text-xs);
  font-weight: 600;
  color: #6ba3a0;
  margin-bottom: var(--space-1);
  text-transform: uppercase;
  letter-spacing: 0.04em;
}

/* View matrix CTA */
.view-matrix-cta {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  margin-top: var(--space-6);
  padding: var(--space-3) var(--space-5);
  font-family: var(--font-display);
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--color-primary);
  background: transparent;
  border: 1px solid var(--color-primary);
  border-radius: var(--radius-md);
  cursor: pointer;
  transition: all var(--transition-interactive);
}

.view-matrix-cta:hover {
  background: rgba(212, 148, 60, 0.08);
  color: var(--color-primary-hover);
  border-color: var(--color-primary-hover);
}

.view-matrix-cta svg {
  width: 14px; height: 14px;
  transition: transform var(--transition-interactive);
}
.view-matrix-cta:hover svg {
  transform: translateX(3px);
}

/* ============================================
   CROSS-PERSPECTIVE MATRIX
   ============================================ */
.matrix-section {
  padding: var(--space-12) 0;
  border-top: 1px solid var(--color-border-subtle);
}

.matrix-header {
  margin-bottom: var(--space-8);
  max-width: 600px;
}

.matrix-header h2 {
  font-family: var(--font-display);
  font-size: var(--text-2xl);
  font-weight: 800;
  letter-spacing: -0.03em;
  color: var(--color-text);
  margin-bottom: var(--space-3);
}

.matrix-header p {
  font-size: var(--text-base);
  color: var(--color-text-secondary);
  line-height: 1.7;
}

.matrix-scroll {
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  margin: 0 calc(-1 * var(--space-6));
  padding: 0 var(--space-6);
}

.matrix-scroll::-webkit-scrollbar {
  height: 4px;
}
.matrix-scroll::-webkit-scrollbar-track {
  background: var(--color-surface);
}
.matrix-scroll::-webkit-scrollbar-thumb {
  background: var(--color-border);
  border-radius: 2px;
}

.matrix-table {
  width: 100%;
  min-width: 900px;
  border-collapse: separate;
  border-spacing: 0;
}

.matrix-table thead th {
  font-family: var(--font-display);
  font-size: var(--text-xs);
  font-weight: 700;
  color: var(--color-text-muted);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  padding: var(--space-3) var(--space-4);
  text-align: left;
  border-bottom: 2px solid var(--color-border);
  position: sticky;
  top: 0;
  background: var(--color-bg);
  z-index: 2;
  white-space: nowrap;
}

.matrix-table thead th:first-child {
  position: sticky;
  left: 0;
  z-index: 3;
  background: var(--color-bg);
  min-width: 160px;
}

.matrix-table tbody td {
  font-size: var(--text-xs);
  color: var(--color-text-secondary);
  line-height: 1.55;
  padding: var(--space-3) var(--space-4);
  border-bottom: 1px solid var(--color-border-subtle);
  vertical-align: top;
  min-width: 150px;
  max-width: 200px;
}

.matrix-table tbody td:first-child {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: var(--text-sm);
  color: var(--color-text);
  position: sticky;
  left: 0;
  background: var(--color-bg);
  z-index: 1;
  min-width: 160px;
  white-space: nowrap;
}

.matrix-table tbody tr:hover td {
  background: var(--color-surface);
}

.matrix-table tbody tr:hover td:first-child {
  background: var(--color-surface);
}

.matrix-table tbody tr:last-child td {
  border-bottom: none;
}

/* Highlight column on hover */
.matrix-table th.col-highlight,
.matrix-table td.col-highlight {
  background: var(--color-surface) !important;
}

/* Mobile card-based matrix fallback */
.matrix-cards { display: none; }

@media (max-width: 768px) {
  .matrix-scroll { display: none; }
  .matrix-cards { display: block; }

  .matrix-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    margin-bottom: var(--space-4);
  }

  .matrix-card-topic {
    font-family: var(--font-display);
    font-size: var(--text-sm); font-weight: 700;
    color: var(--color-primary);
    margin-bottom: var(--space-4); padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border-subtle);
    letter-spacing: -0.01em;
  }

  .matrix-card-row {
    padding: var(--space-2) 0;
    border-bottom: 1px solid var(--color-border-subtle);
  }
  .matrix-card-row:last-child { border-bottom: none; }

  .matrix-card-persona {
    font-family: var(--font-display);
    font-size: var(--text-xs); font-weight: 700;
    color: var(--color-text-muted);
    text-transform: uppercase; letter-spacing: 0.04em;
    margin-bottom: var(--space-1);
  }

  .matrix-card-text {
    font-size: var(--text-xs); color: var(--color-text-secondary);
    line-height: 1.55;
  }
}

/* ============================================
   WHY THIS PAGE EXISTS
   ============================================ */
.why-section {
  padding: var(--space-12) 0;
  border-top: 1px solid var(--color-border-subtle);
}

.why-heading {
  font-family: var(--font-display);
  font-size: var(--text-lg); font-weight: 700;
  color: var(--color-text); letter-spacing: -0.01em;
  margin-bottom: var(--space-5);
}

.why-content {
  max-width: 620px;
}

.why-content p {
  font-size: var(--text-sm); color: var(--color-text-secondary);
  line-height: 1.7; margin-bottom: var(--space-4);
}

.why-content p:last-child {
  margin-bottom: 0;
  color: var(--color-text-muted); font-style: italic;
}

/* ============================================
   SOURCES / DATA FOOTER
   ============================================ */
.sources-section {
  padding: var(--space-10) 0;
  border-top: 1px solid var(--color-border-subtle);
}

.sources-label {
  font-family: var(--font-display);
  font-size: var(--text-xs);
  font-weight: 700;
  color: var(--color-text-muted);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-bottom: var(--space-4);
}

.sources-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.sources-list li {
  font-size: var(--text-xs);
  color: var(--color-text-faint);
  line-height: 1.6;
  padding: var(--space-1) 0;
}

.sources-list a {
  color: var(--color-text-muted);
  text-decoration: none;
}

.sources-list a:hover {
  color: var(--color-primary);
  text-decoration: underline;
}

/* Stat pills in sources */
.stat-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-3);
  margin-top: var(--space-4);
  margin-bottom: var(--space-6);
}

.stat-pill {
  display: flex;
  flex-direction: column;
  padding: var(--space-3) var(--space-4);
  background: var(--color-surface);
  border: 1px solid var(--color-border-subtle);
  border-radius: var(--radius-md);
  min-width: 120px;
}

.stat-pill-value {
  font-family: var(--font-display);
  font-size: var(--text-lg);
  font-weight: 800;
  color: var(--color-primary);
  letter-spacing: -0.02em;
}

.stat-pill-label {
  font-size: var(--text-xs);
  color: var(--color-text-muted);
  line-height: 1.4;
}

.data-freshness {
  font-size: var(--text-xs); color: var(--color-text-faint);
  margin-bottom: var(--space-4); font-style: italic;
}

/* ============================================
   FOOTER (matching hub)
   ============================================ */
.site-footer {
  margin-top: auto; padding: var(--space-8) 0;
  border-top: 1px solid var(--color-border-subtle);
}

.footer-inner {
  display: flex; align-items: center; justify-content: space-between;
  gap: var(--space-4); flex-wrap: wrap;
}
.footer-left { font-size: var(--text-xs); color: var(--color-text-faint); }
.footer-left a { color: var(--color-primary); text-decoration: none; }
.footer-left a:hover { text-decoration: underline; }
.footer-right { display: flex; align-items: center; gap: var(--space-4); }
.footer-right a { font-size: var(--text-xs); color: var(--color-text-faint); text-decoration: none; }
.footer-right a:hover { color: var(--color-text-muted); }

/* ============================================
   SHARE DROPDOWN
   ============================================ */
.share-wrap {
  position: relative;
  display: inline-block;
}

.share-btn {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-2) var(--space-3);
  font-size: var(--text-xs);
  font-weight: 600;
  color: var(--color-text-muted);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  cursor: pointer;
  transition: all var(--transition-interactive);
  background: transparent;
}

.share-btn:hover {
  color: var(--color-text);
  border-color: var(--color-border);
  background: var(--color-surface);
}

.share-btn svg {
  width: 14px; height: 14px;
}

.share-dropdown {
  position: absolute;
  bottom: calc(100% + var(--space-2));
  right: 0;
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  padding: var(--space-2);
  min-width: 210px;
  z-index: 1000;
  opacity: 0;
  pointer-events: none;
  transform: translateY(4px);
  transition: opacity var(--transition-interactive), transform var(--transition-interactive);
}

.share-dropdown.open {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

.share-dropdown-item {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  width: 100%;
  padding: var(--space-2) var(--space-3);
  border-radius: var(--radius-sm);
  font-size: var(--text-sm);
  font-family: var(--font-body);
  color: var(--color-text);
  background: none;
  border: none;
  cursor: pointer;
  text-decoration: none;
  transition: background var(--transition-interactive);
}

.share-dropdown-item:hover {
  background: var(--color-surface-2);
}

.share-dropdown-item svg {
  flex-shrink: 0;
  width: 16px;
  height: 16px;
}

/* ============================================
   FADE-IN ANIMATIONS
   ============================================ */
.fade-in {
  opacity: 0;
  transform: translateY(12px);
  transition: opacity 500ms cubic-bezier(0.16, 1, 0.3, 1),
              transform 500ms cubic-bezier(0.16, 1, 0.3, 1);
}

.fade-in.visible {
  opacity: 1;
  transform: translateY(0);
}

/* Staggered children */
.stagger > * {
  opacity: 0;
  transform: translateY(8px);
  transition: opacity 400ms cubic-bezier(0.16, 1, 0.3, 1),
              transform 400ms cubic-bezier(0.16, 1, 0.3, 1);
}

.stagger.visible > * {
  opacity: 1;
  transform: translateY(0);
}

.stagger.visible > *:nth-child(1) { transition-delay: 0ms; }
.stagger.visible > *:nth-child(2) { transition-delay: 60ms; }
.stagger.visible > *:nth-child(3) { transition-delay: 120ms; }
.stagger.visible > *:nth-child(4) { transition-delay: 180ms; }
.stagger.visible > *:nth-child(5) { transition-delay: 240ms; }
</style>
</head>

<body>

  <!-- ====== NAV ====== -->
  <nav class="nav" role="navigation" aria-label="Main navigation">
    <div class="container nav-inner">
      <a href="https://gamedevai.guide/" class="nav-logo" aria-label="Game Dev AI Guide home">
        <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect x="2" y="2" width="28" height="28" rx="6" stroke="currentColor" stroke-width="2"/>
          <path d="M10 22V10l6 5 6-5v12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" opacity="0.85"/>
          <circle cx="16" cy="16" r="2" fill="#d4943c"/>
        </svg>
        <span class="nav-logo-text">Game Dev AI Guide</span>
      </a>

      <div class="nav-right">
        <ul class="nav-links" role="list" id="navLinks">
          <li><a href="https://gamedevai.guide/">Home</a></li>
          <li><a href="https://gamedevai.guide/ai-tools/"><span class="nav-dot" style="background:#d4943c"></span>AI Tools</a></li>
          <li><a href="https://gamedevai.guide/nvidia-toolkit/"><span class="nav-dot" style="background:#76b900"></span>NVIDIA Toolkit</a></li>
          <li><a href="https://gamedevai.guide/jobs/"><span class="nav-dot" style="background:#d4943c"></span>Job Search</a></li>
          <li><a href="https://gamedevai.guide/perspectives/" class="active"><span class="nav-dot" style="background:#d4943c"></span>Perspectives</a></li>
        </ul>

        <button class="nav-mobile-toggle" id="mobileToggle" aria-label="Toggle navigation menu" aria-expanded="false">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <main>
    <!-- ====== HERO ====== -->
    <section class="hero">
      <div class="container">
        <div class="hero-content">
          <p class="hero-label">The AI perception gap</p>
          <h1>Same tools.<br>Different realities.</h1>
          <p class="hero-sub">Five roles in game development. Five informed, contradictory views of the same technology. Every perspective gets something right. Every perspective has blind spots.</p>
          <p class="hero-byline">Built by <a href="https://www.linkedin.com/in/joehalper/" target="_blank" rel="noopener noreferrer">Joe Halper</a>, game dev, not an AI company</p>
          <p class="hero-disclaimer">This is a perspective piece, not a study. Statistics are from the <a href="https://gdconf.com/article/gdc-2026-state-of-the-game-industry-reveals-impact-of-layoffs-generative-ai-and-more/" target="_blank" rel="noopener noreferrer">GDC 2026 State of the Industry report</a>. Persona characterizations are informed by industry patterns, not survey categories.</p>
        </div>
      </div>
    </section>

    <!-- ====== PERSONA SELECTOR ====== -->
    <section class="persona-section" id="personas">
      <div class="container">
        <p class="section-label">Where are you coming from?</p>
        <div class="persona-grid stagger" id="personaGrid">

          <button class="persona-card" data-persona="executive" aria-pressed="false">
            <span class="persona-card-title">Studio Executive / Producer</span>
            <span class="persona-card-quote">"I see AI as a way to hit targets and ship faster"</span>
          </button>

          <button class="persona-card" data-persona="creative" aria-pressed="false">
            <span class="persona-card-title">Hands-On Creative</span>
            <span class="persona-card-quote">"I see AI as a threat to craft and jobs"</span>
          </button>

          <button class="persona-card" data-persona="engineer" aria-pressed="false">
            <span class="persona-card-title">Engineer / Technical</span>
            <span class="persona-card-quote">"I see AI as a tool. Some good, some overhyped"</span>
          </button>

          <button class="persona-card" data-persona="indie" aria-pressed="false">
            <span class="persona-card-title">Indie / Solo Dev</span>
            <span class="persona-card-quote">"I see AI as a force multiplier for my tiny team"</span>
          </button>

          <button class="persona-card" data-persona="enterprise" aria-pressed="false">
            <span class="persona-card-title">Enterprise / Non-Game</span>
            <span class="persona-card-quote">"I see AI transforming productivity across our org"</span>
          </button>

        </div>

        <!-- ====== PERSONA DETAIL ====== -->
        <div class="persona-detail-wrapper" id="personaDetail">
          <div class="persona-detail">
            <div class="persona-detail-header">
              <h2 class="persona-detail-name" id="detailName"></h2>
              <p class="persona-detail-stance" id="detailStance"></p>
            </div>

            <!-- Real voices -->
            <div class="persona-quotes" id="personaQuotes"></div>

            <!-- Common positions (full width) -->
            <div class="detail-full-row">
              <div class="detail-block">
                <p class="detail-block-label">Common positions</p>
                <p class="detail-block-note">Not everyone in this role thinks this way. These are patterns, not universals.</p>
                <ul id="detailBelieve"></ul>
              </div>
            </div>

            <!-- Right + Wrong (two columns) -->
            <div class="detail-columns">
              <div class="detail-block detail-block--right">
                <p class="detail-block-label">What you get right</p>
                <ul id="detailRight"></ul>
              </div>
              <div class="detail-block detail-block--blindspots">
                <p class="detail-block-label">Blind spots</p>
                <ul id="detailWrong"></ul>
              </div>
            </div>

            <!-- What you're missing (full width) -->
            <div class="detail-full-row" style="margin-top: var(--space-6);">
              <div class="detail-block detail-block--missing">
                <p class="detail-block-label">What you're missing from other perspectives</p>
                <ul id="detailMissing"></ul>
              </div>
            </div>

            <button class="view-matrix-cta" id="viewMatrixBtn" onclick="document.getElementById('matrix').scrollIntoView({behavior:'smooth'});">
              See all perspectives side by side
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- ====== CROSS-PERSPECTIVE MATRIX ====== -->
    <section class="matrix-section" id="matrix">
      <div class="container">
        <div class="matrix-header">
          <h2>The same topic, five lenses</h2>
          <p>Each row is an AI capability. Each column is a perspective. Read across to see how the same technology looks completely different depending on where you sit.</p>
        </div>

        <div class="matrix-scroll">
          <table class="matrix-table" id="matrixTable">
            <thead>
              <tr>
                <th>AI Topic</th>
                <th>Executive</th>
                <th>Creative</th>
                <th>Engineer</th>
                <th>Indie Dev</th>
                <th>Enterprise</th>
              </tr>
            </thead>
            <tbody id="matrixBody"></tbody>
          </table>
        </div>

        <!-- Mobile card-based fallback -->
        <div class="matrix-cards" id="matrixCards"></div>
      </div>
    </section>

    <!-- ====== WHY THIS PAGE EXISTS ====== -->
    <section class="why-section">
      <div class="container">
        <h2 class="why-heading">Why this page exists</h2>
        <div class="why-content">
          <p>The AI conversation in game development is splitting into camps. Executives, creatives, engineers, indie devs, and enterprise observers are all talking about the same technology but reaching completely different conclusions, and the divide is getting wider. People are stopping listening to each other and starting to perform their position instead.</p>
          <p>That's not because anyone is wrong. It's because each role has access to different evidence, different incentives, and different consequences. When you only hear your own side long enough, the other side starts to sound irrational.</p>
          <p>This page is trying to bridge that gap before it becomes permanent. It maps where each perspective is grounded, where it has blind spots, and what it's missing from the others. The goal is to help teams have better AI conversations by making the disagreements legible instead of tribal.</p>
          <p>If your studio is stuck in an AI debate where nobody's budging, send this to both sides.</p>
        </div>
      </div>
    </section>

    <!-- ====== KEY DATA / SOURCES ====== -->
    <section class="sources-section">
      <div class="container">
        <p class="sources-label">Key data from GDC 2026 State of the Industry</p>
        <p class="data-freshness">Data as of: GDC 2026, January 2026</p>
        <div class="stat-grid">
          <div class="stat-pill">
            <span class="stat-pill-value">52%</span>
            <span class="stat-pill-label">view AI negatively (up from 18%)</span>
          </div>
          <div class="stat-pill">
            <span class="stat-pill-value">7%</span>
            <span class="stat-pill-label">view AI positively (down from 21%)</span>
          </div>
          <div class="stat-pill">
            <span class="stat-pill-value">36%</span>
            <span class="stat-pill-label">use AI in daily work</span>
          </div>
          <div class="stat-pill">
            <span class="stat-pill-value">47%</span>
            <span class="stat-pill-label">upper management AI usage</span>
          </div>
          <div class="stat-pill">
            <span class="stat-pill-value">29%</span>
            <span class="stat-pill-label">individual contributor usage</span>
          </div>
          <div class="stat-pill">
            <span class="stat-pill-value">78%</span>
            <span class="stat-pill-label">of studios now have AI policies</span>
          </div>
        </div>

        <p class="sources-label" style="margin-top: var(--space-6);">Sources</p>
        <ul class="sources-list" role="list">
          <li><a href="https://gdconf.com/article/gdc-2026-state-of-the-game-industry-reveals-impact-of-layoffs-generative-ai-and-more/" target="_blank" rel="noopener noreferrer">GDC 2026 State of the Game Industry Survey</a>. All sentiment, usage, and policy statistics cited above.</li>
          <li><a href="https://www.gamedeveloper.com/business/one-third-of-game-workers-use-generative-ai-but-half-think-it-s-bad-for-the-industry" target="_blank" rel="noopener noreferrer">Game Developer</a>: Usage breakdowns: Research/brainstorming 81%, Code assistance 47%, Daily tasks 47%, Prototyping 35%, Asset generation 19%.</li>
          <li><a href="https://www.gamedeveloper.com/business/survey-one-in-four-developers-laid-off-over-the-past-two-years" target="_blank" rel="noopener noreferrer">Game Developer</a>: Opposition by discipline: Visual/technical artists 64%, Game designers/narrative 63%, Programmers 59%.</li>
          <li><a href="https://www.businesswire.com/news/home/20260129438528/en/" target="_blank" rel="noopener noreferrer">Business Wire</a>: Business/finance role usage grew from 44% (2024) to 58% (2026). "Select tools allowed" policies grew from 7% to 22%.</li>
          <li><a href="https://www.pcgamer.com/gaming-industry/one-third-of-us-games-industry-workers-were-laid-off-in-the-last-2-years-gdc-survey-says/" target="_blank" rel="noopener noreferrer">PC Gamer</a>: Job impact: 17% experienced job loss within 12 months, 28% within 2 years. 30% of AAA studios use proprietary AI systems.</li>
        </ul>
      </div>
    </section>
  </main>

  <!-- ====== FOOTER ====== -->
  <footer class="site-footer">
